# ============================================================
# .env.example — Variables d'entorn per Deduction Duel
# ============================================================
# Copia aquest fitxer a .env i omple els valors.
#
#   cp .env.example .env
#
# IMPORTANT: No comparteixis mai el .env amb ningú!
# ============================================================

# --- Supabase (OBLIGATORI) ------------------------------------
# URL del teu projecte Supabase (cloud o self-hosted)
# Exemple: https://abcdefghijklmn.supabase.co
VITE_SUPABASE_URL=

# Clau pública/anon de Supabase (safe per al client)
# La trobes a: Supabase Dashboard → Settings → API → anon key
VITE_SUPABASE_PUBLISHABLE_KEY=

# ID del projecte Supabase (opcional, usat per URLs internes)
VITE_SUPABASE_PROJECT_ID=

# --- Docker (OPCIONAL) ----------------------------------------
# Port on servir l'app (per defecte: 8080)
APP_PORT=8080
